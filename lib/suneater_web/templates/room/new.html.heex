<div>
  <h2>Create a Community Custom Room</h2>
  <%= form_for @changeset, Routes.room_path(@conn, :create), fn f -> %>
    <div>
      <%= label f, :name %>
      <%= text_input f, :name  %>
      <%= error_tag f, :name %>
    </div>
    <div>
      <%= label f, :description %>
      <%= text_input f, :description  %>
      <%= error_tag f, :description %>
    </div>
    <div>
      <%= submit "Submit" %>
    </div>
  <% end %>
</div>
